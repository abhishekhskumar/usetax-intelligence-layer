# SAP AI Core (Claude via Orchestration)
AI_CORE_AUTH_URL=https://<subaccount>.authentication.<region>.hana.ondemand.com/oauth/token
AI_CORE_CLIENT_ID=<your-ai-core-client-id>
AI_CORE_CLIENT_SECRET=<your-ai-core-client-secret>
AI_CORE_DEPLOYMENT_URL=https://api.ai.<region>.aws.ml.hana.ondemand.com/v2/inference/deployments/<id>/completion
AI_CORE_RESOURCE_GROUP=use-tax
AI_CORE_MODEL=anthropic--claude-4.5-sonnet

# SAP Document AI
DOC_AI_URL=https://aiservices-dox.cfapps.<region>.hana.ondemand.com
DOC_AI_TOKEN_URL=https://<subaccount>.authentication.<region>.hana.ondemand.com/oauth/token
DOC_AI_CLIENT_ID=<your-doc-ai-client-id>
DOC_AI_CLIENT_SECRET=<your-doc-ai-client-secret>

# Document AI Schema IDs
DOC_AI_SCHEMA_INDEXING=<indexing-schema-id>
DOC_AI_SCHEMA_NON_CONSTRUCTION=<primary-schema-id>
DOC_AI_SCHEMA_CONSTRUCTION=<mission-schema-id>